{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "dria",
  "version": "1.0.0",
  "identifier": "com.dev.dria.desktop",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "title": "dria",
        "width": 420,
        "height": 560,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "dria — AI Study Assistant"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
